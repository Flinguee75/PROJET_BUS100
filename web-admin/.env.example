# ============================================================================
# Configuration du Dashboard Web Admin
# ============================================================================
# Copiez ce fichier en `.env` puis adaptez les valeurs.
#
# Deux modes de fonctionnement :
#
#   1) MODE DÉMO (par défaut si Firebase n'est pas configuré)
#      → Bus simulés qui roulent vers l'école, AUCUN backend ni Firebase requis.
#      → Idéal pour une démonstration en école.
#      → Seul le token Mapbox ci-dessous est nécessaire (fond de carte).
#
#   2) MODE RÉEL (quand toute la config Firebase est renseignée)
#      → Données live depuis Firestore + Cloud Functions.
# ============================================================================

# --- Mode démo --------------------------------------------------------------
# "true"  : force le mode démo même si Firebase est configuré.
# vide     : le mode démo s'active automatiquement tant que Firebase n'est pas
#            entièrement configuré ci-dessous.
VITE_DEMO_MODE=true

# --- Mapbox (REQUIS, y compris en mode démo) --------------------------------
# La carte a besoin d'un token Mapbox pour afficher le fond de carte (tuiles).
# Token gratuit : https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# --- Firebase (uniquement pour le MODE RÉEL) --------------------------------
# Laissez vide pour rester en mode démo.
# Valeurs depuis Firebase Console → Project Settings → General.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- API Backend (uniquement pour le MODE RÉEL) -----------------------------
# En local avec les émulateurs :
VITE_API_BASE_URL=http://localhost:5001/projet-bus-60a3f/europe-west4
# En production : https://europe-west4-<project-id>.cloudfunctions.net
